#!/bin/bash

# Setup our path.
kd_add_path_tail "/opt/homebrew/bin"
kd_add_path_tail "$HOME/Library/Application Support/JetBrains/Toolbox/scripts"

# Make `emacs` connect to the daemon on the terminal, and `gemacs`
# spawn the gui version of emacs, also connecting to the daemon.
#
# `emacs` overrides TERM to a custom terminfo entry (tmux-emacs when
# inside tmux, xterm-emacs otherwise) that extends the corresponding
# 256-color base with `setf24`/`setb24` capabilities. Emacs consults
# terminfo strictly: without those it falls back to ANSI 16-color
# approximation (everything looks dim and wrong).
#
# Auto-compile the source into ~/.terminfo on first shell startup if
# either entry isn't loadable — keeps fresh machines self-bootstrapping.
{ infocmp tmux-emacs && infocmp xterm-emacs; } &>/dev/null || \
  tic -x "$HOME/.emacs.terminfo" &>/dev/null

# Run a TTY emacs command with the right TERMINFO so 24-bit
# colors render correctly inside tmux.
_kd_emacs_tty() {
    TERMINFO_DIRS="$HOME/.terminfo:/usr/share/terminfo" \
    TERM=$([ -n "$TMUX" ] && echo tmux-emacs || echo xterm-emacs) \
    "$@"
}

# ee = standalone TTY (no daemon), ec = TTY client (spawns daemon
# if needed), eg = GUI client.
alias ee='_kd_emacs_tty emacs -nw'
alias ec='_kd_emacs_tty emacsclient -t -a ""'
alias eg='open -a /opt/homebrew/opt/emacs-plus/Emacs\ Client.app'
